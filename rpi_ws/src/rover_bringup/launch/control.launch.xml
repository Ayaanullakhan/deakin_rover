<launch>
  <!-- Control launch — e-stop and arm controller (motor_node).
       E-stop launches first as the highest-priority safety node.

       JOYSTICK: Teleop is handled browser-side. The GUI's useGamepad hook
       publishes /cmd_vel (drive) and /joy (arm → motor_node) directly.
       joy_teleop_node is not launched here to avoid double-publishing /cmd_vel.

       MOCK MODE: Fully functional without physical hardware.
  -->

  <arg name="use_mock" default="true" description="Use mock mode for arm (no CAN hardware)"/>

  <!-- E-Stop (must start first — highest priority safety node) -->
  <node pkg="rover_estop" exec="estop_node" name="estop_node" output="screen">
    <param name="watchdog_timeout_sec" value="5.0"/>
    <param name="require_manual_reset" value="true"/>
  </node>

  <!-- Arm Controller (motor_node — IK/FK + CAN) -->
  <include file="$(find-pkg-share rover_bringup)/launch/arm.launch.xml">
    <arg name="use_mock" value="$(var use_mock)"/>
  </include>
</launch>
