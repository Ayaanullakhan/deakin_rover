<launch>
  <!-- Master launch — starts the entire Deakin Rover system.
       Layers: infrastructure → hardware → control → monitoring

  USAGE:
    ros2 launch rover_bringup rover.launch.xml
    ros2 launch rover_bringup rover.launch.xml use_mock:=false

  PORTS:
    9090 — rosbridge WebSocket (Next.js GUI)
    8765 — Foxglove Bridge WebSocket
    8080 — web_video_server MJPEG streams
  -->

  <arg name="use_mock" default="true" description="Use mock hardware mode"/>
  <arg name="rosbridge_port" default="9091" description="rosbridge WebSocket port"/>
  <arg name="foxglove_port" default="8765" description="Foxglove Bridge WebSocket port"/>
  <arg name="video_port" default="8080" description="web_video_server HTTP port"/>

  <!-- Layer 1: Infrastructure -->
  <include file="$(find-pkg-share rover_bringup)/launch/infrastructure.launch.xml">
    <arg name="rosbridge_port" value="$(var rosbridge_port)"/>
    <arg name="video_port" value="$(var video_port)"/>
  </include>

  <!-- Layer 2: Hardware — Python file needed to run xacro for controller_manager -->
  <include file="$(find-pkg-share rover_bringup)/launch/hardware.launch.py">
    <arg name="use_mock" value="$(var use_mock)"/>
  </include>

  <!-- Layer 3: Control -->
  <include file="$(find-pkg-share rover_bringup)/launch/control.launch.xml">
    <arg name="use_mock" value="$(var use_mock)"/>
  </include>

  <!-- Layer 4: Monitoring -->
  <include file="$(find-pkg-share rover_bringup)/launch/monitoring.launch.xml">
    <arg name="use_mock" value="$(var use_mock)"/>
  </include>
</launch>
