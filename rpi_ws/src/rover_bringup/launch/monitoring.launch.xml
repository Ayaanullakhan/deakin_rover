<launch>
  <!-- Monitoring launch — system monitor (battery, network, node telemetry).
       Publishes telemetry to the GUI Status Dashboard.

       MOCK MODE: Battery is simulated. Network and nodes are real.
       HARDWARE UPGRADE: Set use_mock:=false for real battery sensor.
  -->

  <arg name="use_mock" default="true" description="Mock battery sensor (network/nodes are always real)"/>

  <node pkg="rover_monitor" exec="system_monitor_node" name="system_monitor_node" output="screen">
    <param name="use_mock" value="$(var use_mock)"/>
    <param name="power_topic_rate_hz" value="1.0"/>
    <param name="network_topic_rate_hz" value="2.0"/>
    <param name="node_list_rate_hz" value="1.0"/>
    <param name="battery_cells" value="6"/>
    <param name="ping_host" value="192.168.1.1"/>
  </node>
</launch>
