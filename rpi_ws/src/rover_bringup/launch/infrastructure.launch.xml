<launch>
  <!-- Infrastructure launch — rosbridge, web_video_server, TF.
       Provides GUI connectivity:
         - rosbridge_server on port 9090 (Next.js GUI via roslib)
         - web_video_server on port 8080 (MJPEG camera streams)
         - robot_state_publisher + joint_state_publisher (TF tree)
  -->

  <arg name="rosbridge_port" default="9091" description="WebSocket port for rosbridge"/>
  <arg name="video_port" default="8080" description="HTTP port for web_video_server"/>

  <!-- rosbridge_server (primary GUI connection) -->
  <node pkg="rosbridge_server" exec="rosbridge_websocket" name="rosbridge_websocket" output="screen">
    <param name="port" value="$(var rosbridge_port)"/>
    <param name="address" value=""/>
    <param name="retry_startup_delay" value="5.0"/>
  </node>

  <!-- web_video_server (camera MJPEG streams) -->
  <node pkg="web_video_server" exec="web_video_server" name="web_video_server" output="screen">
    <param name="port" value="$(var video_port)"/>
    <param name="address" value="0.0.0.0"/>
    <param name="server_threads" value="2"/>
    <param name="ros_threads" value="2"/>
  </node>

  <!-- Robot description (TF tree) — Python file needed to run xacro -->
  <include file="$(find-pkg-share rover_description)/launch/description.launch.py"/>
</launch>
