<?xml version="1.0"?>
<!--
  Deakin Rover URDF Model

  TF tree:
    base_footprint → base_link
    base_link → {6 wheels, arm_base_link, 3 camera_links}
    arm_base_link → shoulder_link → upper_arm_link → forearm_link → wrist_link → gripper_link

  HARDWARE UPGRADE:
    - Replace box geometries with actual STL meshes in meshes/ directory
    - Adjust link dimensions to match real rover measurements
    - Update inertial properties from CAD model
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="deakin_rover">

  <!-- ==================== PROPERTIES ==================== -->
  <!-- Chassis dimensions (meters) — HARDWARE UPGRADE: measure real rover -->
  <xacro:property name="chassis_length" value="0.8"/>
  <xacro:property name="chassis_width" value="0.5"/>
  <xacro:property name="chassis_height" value="0.15"/>
  <xacro:property name="chassis_mass" value="15.0"/>

  <!-- Wheel properties -->
  <xacro:property name="wheel_radius" value="0.1"/>
  <xacro:property name="wheel_width" value="0.06"/>
  <xacro:property name="wheel_mass" value="0.5"/>
  <xacro:property name="wheel_separation" value="0.5"/>

  <!-- Wheel positions (from base_link center) -->
  <xacro:property name="front_x" value="0.3"/>
  <xacro:property name="mid_x" value="0.0"/>
  <xacro:property name="rear_x" value="-0.3"/>

  <!-- Arm link lengths (meters) — HARDWARE UPGRADE: measure real arm -->
  <xacro:property name="arm_base_height" value="0.1"/>
  <xacro:property name="upper_arm_length" value="0.3"/>
  <xacro:property name="forearm_length" value="0.25"/>
  <xacro:property name="wrist_length" value="0.1"/>
  <xacro:property name="gripper_length" value="0.08"/>

  <!-- ==================== MACROS ==================== -->

  <!-- Inertia for a box -->
  <xacro:macro name="box_inertia" params="mass x y z">
    <inertial>
      <mass value="${mass}"/>
      <inertia ixx="${mass*(y*y+z*z)/12}" ixy="0" ixz="0"
               iyy="${mass*(x*x+z*z)/12}" iyz="0"
               izz="${mass*(x*x+y*y)/12}"/>
    </inertial>
  </xacro:macro>

  <!-- Inertia for a cylinder -->
  <xacro:macro name="cylinder_inertia" params="mass r l">
    <inertial>
      <mass value="${mass}"/>
      <inertia ixx="${mass*(3*r*r+l*l)/12}" ixy="0" ixz="0"
               iyy="${mass*(3*r*r+l*l)/12}" iyz="0"
               izz="${mass*r*r/2}"/>
    </inertial>
  </xacro:macro>

  <!-- Wheel macro -->
  <xacro:macro name="wheel" params="name x y">
    <link name="${name}">
      <visual>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
        <material name="dark_grey"><color rgba="0.2 0.2 0.2 1"/></material>
      </visual>
      <collision>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
      </collision>
      <xacro:cylinder_inertia mass="${wheel_mass}" r="${wheel_radius}" l="${wheel_width}"/>
    </link>
    <joint name="${name}_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${name}"/>
      <origin xyz="${x} ${y} 0" rpy="${-pi/2} 0 0"/>
      <axis xyz="0 0 1"/>
    </joint>
  </xacro:macro>

  <!-- ==================== BASE ==================== -->

  <link name="base_footprint"/>

  <link name="base_link">
    <visual>
      <geometry><box size="${chassis_length} ${chassis_width} ${chassis_height}"/></geometry>
      <origin xyz="0 0 ${chassis_height/2}"/>
      <material name="blue"><color rgba="0.1 0.1 0.4 1"/></material>
    </visual>
    <collision>
      <geometry><box size="${chassis_length} ${chassis_width} ${chassis_height}"/></geometry>
      <origin xyz="0 0 ${chassis_height/2}"/>
    </collision>
    <xacro:box_inertia mass="${chassis_mass}" x="${chassis_length}" y="${chassis_width}" z="${chassis_height}"/>
  </link>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 ${wheel_radius}"/>
  </joint>

  <!-- ==================== WHEELS ==================== -->

  <xacro:wheel name="left_front_wheel"  x="${front_x}" y="${wheel_separation/2}"/>
  <xacro:wheel name="left_mid_wheel"    x="${mid_x}"   y="${wheel_separation/2}"/>
  <xacro:wheel name="left_rear_wheel"   x="${rear_x}"  y="${wheel_separation/2}"/>
  <xacro:wheel name="right_front_wheel" x="${front_x}" y="${-wheel_separation/2}"/>
  <xacro:wheel name="right_mid_wheel"   x="${mid_x}"   y="${-wheel_separation/2}"/>
  <xacro:wheel name="right_rear_wheel"  x="${rear_x}"  y="${-wheel_separation/2}"/>

  <!-- ==================== ARM ==================== -->

  <link name="arm_base_link">
    <visual>
      <geometry><cylinder radius="0.04" length="${arm_base_height}"/></geometry>
      <origin xyz="0 0 ${arm_base_height/2}"/>
      <material name="grey"><color rgba="0.5 0.5 0.5 1"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="0.04" length="${arm_base_height}"/></geometry>
      <origin xyz="0 0 ${arm_base_height/2}"/>
    </collision>
    <xacro:cylinder_inertia mass="0.5" r="0.04" l="${arm_base_height}"/>
  </link>

  <joint name="arm_base_joint" type="fixed">
    <parent link="base_link"/>
    <child link="arm_base_link"/>
    <origin xyz="0.1 0 ${chassis_height}"/>
  </joint>

  <!-- Joint 1: base_yaw (revolute, Z-axis) -->
  <link name="shoulder_link">
    <visual>
      <geometry><box size="0.06 0.06 0.08"/></geometry>
      <origin xyz="0 0 0.04"/>
      <material name="orange"><color rgba="0.8 0.4 0.1 1"/></material>
    </visual>
    <xacro:box_inertia mass="0.3" x="0.06" y="0.06" z="0.08"/>
  </link>
  <joint name="base_yaw" type="revolute">
    <parent link="arm_base_link"/>
    <child link="shoulder_link"/>
    <origin xyz="0 0 ${arm_base_height}"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" velocity="10.0" effort="1.2"/>
  </joint>

  <!-- Joint 2: shoulder_pitch (revolute, Y-axis) -->
  <link name="upper_arm_link">
    <visual>
      <geometry><box size="0.04 0.04 ${upper_arm_length}"/></geometry>
      <origin xyz="0 0 ${upper_arm_length/2}"/>
      <material name="orange"/>
    </visual>
    <xacro:box_inertia mass="1.0" x="0.04" y="0.04" z="${upper_arm_length}"/>
  </link>
  <joint name="shoulder_pitch" type="revolute">
    <parent link="shoulder_link"/>
    <child link="upper_arm_link"/>
    <origin xyz="0 0 0.08"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" velocity="5.0" effort="12.0"/>
  </joint>

  <!-- Joint 3: elbow_pitch (revolute, Y-axis) -->
  <link name="forearm_link">
    <visual>
      <geometry><box size="0.035 0.035 ${forearm_length}"/></geometry>
      <origin xyz="0 0 ${forearm_length/2}"/>
      <material name="orange"/>
    </visual>
    <xacro:box_inertia mass="0.6" x="0.035" y="0.035" z="${forearm_length}"/>
  </link>
  <joint name="elbow_pitch" type="revolute">
    <parent link="upper_arm_link"/>
    <child link="forearm_link"/>
    <origin xyz="0 0 ${upper_arm_length}"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.35" upper="2.35" velocity="5.0" effort="12.0"/>
  </joint>

  <!-- Joint 4: wrist_roll (revolute, Z-axis) -->
  <link name="wrist_link">
    <visual>
      <geometry><cylinder radius="0.025" length="${wrist_length}"/></geometry>
      <origin xyz="0 0 ${wrist_length/2}"/>
      <material name="grey"/>
    </visual>
    <xacro:cylinder_inertia mass="0.2" r="0.025" l="${wrist_length}"/>
  </link>
  <joint name="wrist_roll" type="revolute">
    <parent link="forearm_link"/>
    <child link="wrist_link"/>
    <origin xyz="0 0 ${forearm_length}"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" velocity="8.0" effort="3.6"/>
  </joint>

  <!-- Joint 5: wrist_pitch (revolute, Y-axis) -->
  <link name="wrist_pitch_link">
    <visual>
      <geometry><box size="0.03 0.03 0.04"/></geometry>
      <origin xyz="0 0 0.02"/>
      <material name="grey"/>
    </visual>
    <xacro:box_inertia mass="0.1" x="0.03" y="0.03" z="0.04"/>
  </link>
  <joint name="wrist_pitch" type="revolute">
    <parent link="wrist_link"/>
    <child link="wrist_pitch_link"/>
    <origin xyz="0 0 ${wrist_length}"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" velocity="8.0" effort="3.6"/>
  </joint>

  <!-- Joint 6: gripper (revolute, Z-axis) -->
  <link name="gripper_link">
    <visual>
      <geometry><box size="0.06 0.08 ${gripper_length}"/></geometry>
      <origin xyz="0 0 ${gripper_length/2}"/>
      <material name="grey"/>
    </visual>
    <xacro:box_inertia mass="0.15" x="0.06" y="0.08" z="${gripper_length}"/>
  </link>
  <joint name="gripper" type="revolute">
    <parent link="wrist_pitch_link"/>
    <child link="gripper_link"/>
    <origin xyz="0 0 0.04"/>
    <axis xyz="0 0 1"/>
    <limit lower="0" upper="1.57" velocity="10.0" effort="1.2"/>
  </joint>

  <!-- ==================== CAMERAS ==================== -->

  <!-- Front camera -->
  <link name="camera1_link">
    <visual>
      <geometry><box size="0.03 0.03 0.03"/></geometry>
      <material name="black"><color rgba="0.1 0.1 0.1 1"/></material>
    </visual>
  </link>
  <joint name="camera1_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera1_link"/>
    <origin xyz="${chassis_length/2} 0 ${chassis_height + 0.05}" rpy="0 0 0"/>
  </joint>

  <!-- Rear camera -->
  <link name="camera2_link">
    <visual>
      <geometry><box size="0.03 0.03 0.03"/></geometry>
      <material name="black"/>
    </visual>
  </link>
  <joint name="camera2_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera2_link"/>
    <origin xyz="${-chassis_length/2} 0 ${chassis_height + 0.05}" rpy="0 0 3.14159"/>
  </joint>

  <!-- Arm camera (mounted on forearm) -->
  <link name="camera3_link">
    <visual>
      <geometry><box size="0.025 0.025 0.025"/></geometry>
      <material name="black"/>
    </visual>
  </link>
  <joint name="camera3_joint" type="fixed">
    <parent link="forearm_link"/>
    <child link="camera3_link"/>
    <origin xyz="0.03 0 ${forearm_length * 0.7}" rpy="0 0.3 0"/>
  </joint>

</robot>
