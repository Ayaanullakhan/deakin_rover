<?xml version="1.0" ?>

<robot name="rover_arm">

    <material name="blue">
        <color rgba="0 0 1 1"/>
    </material>

    <material name="green">
        <color rgba="0 1 0 1"/>
    </material>

    <link name="base_link">
        <visual>
            <geometry>
                <cylinder length="0.05" radius="0.1"/>
            </geometry>
            <origin xyz="0 0 0.025" rpy="0 0 0"/>
            <material name="blue"/>
        </visual>
        <collision>
            <geometry>
                <cylinder length="0.05" radius="0.1"/>
            </geometry>
            <origin xyz="0 0 0.025" rpy="0 0 0"/>
        </collision>
    </link>

    <link name="base_rot">
        <visual>
            <geometry>
                <box size="0.1 0.1 0.07"/>
            </geometry>
            <origin xyz="0 0 0.035" rpy="0 0 0"/>
            <material name="green"/>
        </visual>
        <collision>
            <geometry>
                <box size="0.1 0.1 0.07"/>
            </geometry>
            <origin xyz="0 0 0.035" rpy="0 0 0"/>
        </collision>
    </link>

    <link name="arm1">
        <visual>
            <geometry>
                <cylinder length="0.5" radius="0.02"/>
            </geometry>
            <origin xyz="0 0 0.25" rpy="0 0 0"/>
            <material name="blue"/>
        </visual>
        <collision>
            <geometry>
                <cylinder length="0.5" radius="0.02"/>
            </geometry>
            <origin xyz="0 0 0.25" rpy="0 0 0"/> 
        </collision>
    </link>

    <link name="arm2">
        <visual>
            <geometry>
                <cylinder length="0.5" radius="0.02"/>
            </geometry>
            <origin xyz="0 0 0.25" rpy="0 0 0"/>
            <material name="green"/>
        </visual>
        <collision>
            <geometry>
                <cylinder length="0.5" radius="0.02"/>
            </geometry>
            <origin xyz="0 0 0.25" rpy="0 0 0"/>
        </collision>
    </link>

    <link name="ee_link">
        <visual>
            <geometry>
                <box size="0.1 0.1 0.05"/>
            </geometry>
            <origin xyz="0 0 0.025" rpy="0 0 0"/>
            <material name="blue"/>
        </visual>
        <collision>
            <geometry>
                <box size="0.1 0.1 0.05"/>
            </geometry>
            <origin xyz="0 0 0.025" rpy="0 0 0"/>
        </collision>
    </link>

    <joint name="base_joint" type="revolute">
        <parent link="base_link"/>
        <child link="base_rot"/>
        <origin xyz="0 0 0.05" rpy="0 0 0"/>
        <axis xyz="0 0 1"/>
        <limit effort="1000." velocity="1.0" lower="-3.14" upper="3.14"/>
    </joint>

    <joint name="shoulder_joint" type="revolute">
        <parent link="base_rot"/>
        <child link="arm1"/>
        <origin xyz="0 0 0.05" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
        <limit effort="1000." velocity="1.0" lower="-3.14" upper="3.14"/>
    </joint>
        
    <joint name="elbow_joint" type="revolute">
        <parent link="arm1"/>
        <child link="arm2"/>
        <origin xyz="0 0 0.5" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
        <limit effort="1000." velocity="1.0" lower="-3.14" upper="3.14"/>
    </joint>

    <joint name="ee_joint" type="fixed">
        <parent link="arm2"/>
        <child link="ee_link"/>
        <origin xyz="0 0 0.5" rpy="0 0 0"/>
    </joint>

</robot>