{
  "name": "rpi ros2 jazzy",
  "dockerFile": "Dockerfile",
  "autoForwardPorts": false,
  "runArgs": [
    "--privileged",
    "--network=host"
  ],
  "workspaceMount": "source=${localWorkspaceFolder}/rpi_ws,target=/${localWorkspaceFolderBasename}/rpi_ws,type=bind",
  "workspaceFolder": "/${localWorkspaceFolderBasename}/rpi_ws",
  "mounts": [
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.bash_history,target=/home/vscode/.bash_history,type=bind"
  ],
  "postStartCommand": "colcon build --symlink-install > /tmp/build.log 2>&1 || true"
}